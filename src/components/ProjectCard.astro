---
import Tag from './Tag.astro';
import MangaLabel from './MangaLabel.astro';
import type { Project } from '../data/projects';
const { project } = Astro.props as { project: Project };
---
<article class={`project-card ${project.tone}`}>
  <div class="card-top"><MangaLabel tone={project.tone}>PROJECT {project.number}</MangaLabel><div class="project-markers"><span class="status-dot">● {project.status}</span><span class={`progress-marker ${project.progress === 'COMPLETE' ? 'is-complete' : 'is-progress'}`}>STATUS: {project.progress}</span></div></div>
  <h3>{project.title}</h3><p>{project.description}</p>
  <div class="tag-list">{project.tags.map((tag) => <Tag>{tag}</Tag>)}</div>
  <a class="case-link" href={`/projects/${project.slug}`}>READ PROJECT <span aria-hidden="true">→</span></a>
</article>
