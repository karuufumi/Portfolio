---
import { formatPostDate, getPostSlug, type BlogPost } from '../lib/blog';

interface Props {
  posts: BlogPost[];
  startIndex: number;
}

const { posts, startIndex } = Astro.props;
---

<section class="section container blog-list">
  {posts.map((post, index) => (
    <a class="blog-entry" href={`/notes/${getPostSlug(post)}`}>
      <span class="blog-number">{String(startIndex + index + 1).padStart(2, '0')}</span>
      <div>
        <span class="note-meta">{formatPostDate(post.data.pubDate)}</span>
        <h2>{post.data.title}</h2>
        <p>{post.data.description}</p>
      </div>
      <span class="blog-arrow" aria-hidden="true">→</span>
    </a>
  ))}
</section>
