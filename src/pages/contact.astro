---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrutalCard from '../components/BrutalCard.astro';
import Button from '../components/Button.astro';
import { profile } from '../data/profile';
---

<BaseLayout title="Contact — Karuu">
  <section class="page-hero container contact-hero">
    <p class="eyebrow">CONTACT</p>
    <h1>Get in touch.</h1>
    <p>For internships, entry-level software roles, or technical collaboration.</p>
  </section>

  <section class="section container">
    <BrutalCard tone="pink" class="contact-card">
      <div class="contact-summary">
        <p class="eyebrow">DIRECT CONTACT</p>
        <h2>{profile.name}</h2>
        <p>The quickest way to reach me is by phone. You can also send an email using the address below.</p>
      </div>

      <dl class="contact-methods">
        <div>
          <dt>Phone</dt>
          <dd><a href={profile.phoneHref}>{profile.phoneDisplay}</a></dd>
        </div>
        <div>
          <dt>Email</dt>
          <dd><a class="email-link" data-email={profile.emailEncoded} aria-label={`Email ${profile.name}`}>{profile.emailDisplay}</a></dd>
        </div>
      </dl>

      <div class="contact-resources">
        <Button href="/MyCV_new.pdf" variant="blue">My CV</Button>
        <a class="button plain" href={profile.githubUrl} target="_blank" rel="noreferrer"><img class="social-icon" src="/github.svg" alt="" aria-hidden="true"/>GitHub <span aria-hidden="true">↗</span></a>
        <a class="button plain" href={profile.linkedinUrl} target="_blank" rel="noreferrer"><img class="social-icon" src="/social-media-computer-icons-linkedin-logo-social-media.jpg" alt="" aria-hidden="true"/>LinkedIn <span aria-hidden="true">↗</span></a>
      </div>
    </BrutalCard>
  </section>
</BaseLayout>

<script>
  const emailLink = document.querySelector<HTMLAnchorElement>('.email-link');

  if (emailLink?.dataset.email) {
    emailLink.href = `mailto:${atob(emailLink.dataset.email)}`;
  }
</script>
