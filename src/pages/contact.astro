---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrutalCard from '../components/BrutalCard.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Contact — Karuu">
  <section class="page-hero container contact-hero">
    <p class="eyebrow">CONTACT</p>
    <h1>Get in touch.</h1>
    <p>For internships, entry-level software roles, or technical collaboration.</p>
  </section>

  <section class="section container">
    <BrutalCard tone="pink" class="contact-card">
      <div class="contact-summary">
        <p class="eyebrow">DIRECT CONTACT</p>
        <h2>Nguyễn Tiến Khang</h2>
        <p>The quickest way to reach me is by phone. You can also send an email using the address below.</p>
      </div>

      <dl class="contact-methods">
        <div>
          <dt>Phone</dt>
          <dd><a href="tel:+84903049939">0903 049 939</a></dd>
        </div>
        <div>
          <dt>Email</dt>
          <dd><a class="email-link" data-email="a2hhbmd0aWVuMjRAZ21haWwuY29t" aria-label="Email Nguyễn Tiến Khang">khangtien24 [at] gmail [dot] com</a></dd>
        </div>
      </dl>

      <div class="contact-resources">
        <Button href="/MyCV_new.pdf" variant="blue">My CV</Button>
        <a class="button plain" href="https://github.com/karuufumi">GitHub <span aria-hidden="true">↗</span></a>
        <a class="button plain" href="https://www.linkedin.com/in/tienkhangnguyen">LinkedIn <span aria-hidden="true">↗</span></a>
      </div>
    </BrutalCard>
  </section>
</BaseLayout>

<script>
  const emailLink = document.querySelector<HTMLAnchorElement>('.email-link');

  if (emailLink?.dataset.email) {
    emailLink.href = `mailto:${atob(emailLink.dataset.email)}`;
  }
</script>
