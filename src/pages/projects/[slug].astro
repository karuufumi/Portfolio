---
import BaseLayout from '../../layouts/BaseLayout.astro'; import BrutalCard from '../../components/BrutalCard.astro'; import MangaLabel from '../../components/MangaLabel.astro'; import BrowserMockup from '../../components/BrowserMockup.astro'; import Tag from '../../components/Tag.astro'; import { projects } from '../../data/site';
export function getStaticPaths() { return projects.map(project => ({ params: { slug: project.slug }, props: { project } })); }
const { project } = Astro.props;
---
<BaseLayout title={`${project.title} — Karuu`}><div class="case-layout container"><header class={`case-header brutal-card ${project.tone}`}><MangaLabel tone="yellow">CASE FILE {project.number} / {project.status}</MangaLabel><h1>{project.title}</h1><p>{project.description}</p><div class="tag-list">{project.tags.map((tag: string) => <Tag>{tag}</Tag>)}</div></header><div class="case-grid"><article class="case-content"><section><h2>Overview</h2><p>{project.description} The case file frames the work as an applied systems project: clear constraints, explicit decisions, and a practical interface for investigation.</p></section><section><h2>Problem</h2><p>{project.problem}</p></section><section><h2>System Architecture</h2><BrowserMockup label={`karuu://case-file/${project.slug}`}><div class="architecture"><div>INPUTS<br/><small>events / policies</small></div><div>CORE<br/><small>orchestration</small></div><div>OUTPUTS<br/><small>signals / reports</small></div></div></BrowserMockup></section><section><h2>Key Features</h2><ul>{project.features.map((feature: string) => <li>{feature}</li>)}</ul></section><section><h2>What I Learned</h2><p>{project.learned}</p></section></article><aside class="case-sidebar"><BrutalCard><p class="eyebrow">TECH STACK</p><ul class="stack-list">{project.tags.map((tag: string) => <li>{tag}</li>)}</ul><p style="margin-top:1.3rem"><a class="button secondary" href="#">Repository ↗</a></p></BrutalCard></aside></div></div></BaseLayout>
