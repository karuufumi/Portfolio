---
import BaseLayout from '../../layouts/BaseLayout.astro'; import { notes } from '../../data/site';
---
<BaseLayout title="Blog — Karuu"><section class="page-hero container"><p class="eyebrow">BLOG / ENGINEERING NOTES</p><h1>Blog</h1><p>Short writing on backend systems, cloud delivery, security research, and project work.</p></section><section class="section container blog-list">{notes.map((note, index) => <a class="blog-entry" href={`/notes/${note.slug}`}><span class="blog-number">0{index + 1}</span><div><span class="note-meta">{note.type} · {note.date}</span><h2>{note.title}</h2><p>{note.excerpt}</p></div><span class="blog-arrow" aria-hidden="true">→</span></a>)}</section></BaseLayout>
