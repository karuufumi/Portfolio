---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogList from '../../../components/BlogList.astro';
import BlogPagination from '../../../components/BlogPagination.astro';
import { BLOG_PAGE_SIZE, getPublishedPosts } from '../../../lib/blog';

export async function getStaticPaths() {
  const pageSize = BLOG_PAGE_SIZE;
  const posts = await getPublishedPosts();
  const totalPages = Math.ceil(posts.length / pageSize);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const currentPage = index + 2;
    const startIndex = (currentPage - 1) * pageSize;

    return {
      params: { page: String(currentPage) },
      props: {
        currentPage,
        totalPages,
        startIndex,
        pagePosts: posts.slice(startIndex, startIndex + pageSize),
      },
    };
  });
}

const { currentPage, totalPages, startIndex, pagePosts } = Astro.props;
---

<BaseLayout title={`Blog — Page ${currentPage} — Karuu`}><section class="page-hero container"><h1>Blog</h1><p>Short writing on backend systems, cloud delivery, security research, and project work.</p></section><BlogList posts={pagePosts} startIndex={startIndex} /><BlogPagination currentPage={currentPage} totalPages={totalPages} /></BaseLayout>
