---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { notes } from '../../data/blog';

export function getStaticPaths() {
  return notes.map((note) => ({ params: { slug: note.slug }, props: { note } }));
}

const { note } = Astro.props;
---

<BaseLayout title={`${note.title} — Karuu`}>
  <article class="article">
    <p class="article-meta">{note.date}</p>
    <h1>{note.title}</h1>
    <p class="eyebrow">BLOG POST / KARUU</p>
    {note.sections.map((section) => (
      <section>
        <h2>{section.heading}</h2>
        {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </section>
    ))}
  </article>
</BaseLayout>
