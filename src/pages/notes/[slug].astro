---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { render } from 'astro:content';
import { formatPostDate, getPostSlug, getPublishedPosts } from '../../lib/blog';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({ params: { slug: getPostSlug(post) }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Karuu`}>
  <article class="article">
    <p class="article-meta">{formatPostDate(post.data.pubDate)}</p>
    <h1>{post.data.title}</h1>
    <ul class="article-tags" aria-label="Post tags">{post.data.tags.map((tag) => <li>{tag}</li>)}</ul>
    <Content />
  </article>
</BaseLayout>
