---
import BaseLayout from '../layouts/BaseLayout.astro'; import BrutalCard from '../components/BrutalCard.astro'; import Button from '../components/Button.astro'; import MangaLabel from '../components/MangaLabel.astro'; import TickerStrip from '../components/TickerStrip.astro'; import ProjectCard from '../components/ProjectCard.astro'; import { projects, notes } from '../data/site';
---
<BaseLayout>
  <section class="hero container"><div class="hero-grid toon-hero-grid">
    <BrutalCard class="hero-main"><MangaLabel tone="green">● AVAILABLE FOR SELECTED PROJECTS</MangaLabel><h1>Hey, I’m Karuu!<br/>I build systems<br/>that hold up.</h1><p class="hero-copy">I turn backend, cloud, DevOps, and security problems into reliable software with a clear interface and a point of view.</p><div class="hero-buttons"><Button href="/projects">View my work</Button><Button href="/contact" variant="secondary">Let’s talk</Button></div></BrutalCard>
    <BrutalCard tone="pink" class="profile-poster"><span class="spark crown" aria-hidden="true">✦</span><div class="avatar-orbit"><div class="avatar-head"><span class="avatar-glasses">⌁</span></div><div class="avatar-body"></div></div><h2>Karuu</h2><p>Software Engineer<br/>&amp; Systems Builder</p><MangaLabel tone="yellow">ENGINEER! ⚡</MangaLabel></BrutalCard>
    <aside class="hero-side"><BrutalCard tone="blue" class="hero-status"><p class="status-title">CURRENTLY BUILDING <span aria-hidden="true">⌘</span></p><p class="status-big">Container<br/>Security Sandbox<small>Restricted runtime testing and observable policy boundaries.</small></p><p class="mini-status">● Coding in Go...</p></BrutalCard><BrutalCard tone="yellow" class="hero-status"><p class="status-title">SPECIALTY <span aria-hidden="true">⚡</span></p><p class="status-big">Backend &amp;<br/>Cloud Systems</p><a class="case-link" href="/about">READ PROFILE →</a></BrutalCard></aside>
  </div><div class="mini-grid"><BrutalCard tone="green" class="mini-card"><p class="status-title">SHIPPED BUILDS <span>🚀</span></p><strong>04</strong><p>case files in the archive</p></BrutalCard><BrutalCard tone="purple" class="mini-card"><p class="status-title">BUILD PRINCIPLE <span>✎</span></p><strong>Make it<br/>observable.</strong><p>Architecture should explain itself.</p></BrutalCard><div class="hero-note"><span>✦</span> SYSTEMS, NOT<br/>JUST SURFACES.</div></div></section>
  <TickerStrip />
  <section class="section container showcase-section"><div class="section-heading centered-heading"><div><MangaLabel tone="purple">PORTFOLIO SHOW</MangaLabel><h2>Selected System Builds</h2><p>Case files for platforms, experiments, and applied engineering work.</p></div></div><div class="project-grid showcase-grid">{projects.slice(0,2).map((project) => <ProjectCard project={project} />)}</div><p class="center-action"><Button href="/projects" variant="plain">Browse Project Catalog</Button></p></section>
  <section class="section container process-section"><div class="section-heading centered-heading"><div><MangaLabel tone="green">HOW I WORK</MangaLabel><h2>My Engineering Storyboard</h2></div></div><div class="process-list"><article><b>1</b><div><h3>Discover</h3><p>Clarify the system boundary, risk, outcomes, and constraints before selecting a stack.</p></div><span>⌕</span></article><article><b>2</b><div><h3>Model</h3><p>Map the data, service contracts, failure paths, and behavior that needs to be observable.</p></div><span>◇</span></article><article><b>3</b><div><h3>Build</h3><p>Implement focused components, test critical paths, and keep the developer workflow simple.</p></div><span>⌘</span></article><article><b>4</b><div><h3>Ship</h3><p>Document decisions, deploy deliberately, and leave the system easier to operate than before.</p></div><span>↗</span></article></div></section>
  <section class="section container"><div class="section-heading"><div><p class="eyebrow">FIELD RECORDS</p><h2>Field Notes</h2></div><p>Short writeups on systems, cloud, thesis work, and things I am learning.</p></div><div class="notes-grid">{notes.slice(0,2).map(note => <a class="note-card" href={`/notes/${note.slug}`}><span class="note-meta">{note.type} · {note.date}</span><h3>{note.title}</h3><p>{note.excerpt}</p></a>)}</div></section>
  <section class="section container"><BrutalCard tone="pink" class="contact-cta"><div><p class="eyebrow">OPEN CHANNEL</p><h2>Want to build or discuss something technical?</h2></div><div><p>Send a message if you want to talk about backend systems, cloud platforms, security testing, or applied software engineering.</p><p style="margin-top:1.25rem"><Button href="/contact" variant="plain">Contact Karuu</Button></p></div></BrutalCard></section>
</BaseLayout>
