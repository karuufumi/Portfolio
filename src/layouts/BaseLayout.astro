---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
interface Props { title?: string; description?: string; }
const { title = 'Karuu — Software Systems Portfolio', description = 'Backend systems, cloud platforms, DevOps, and security-focused software.' } = Astro.props;
---
<!doctype html><html lang="en"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width"/><meta name="description" content={description}/><title>{title}</title><ClientRouter /></head>
<body><Navbar /><main><slot /></main><Footer /></body></html>
